{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vibe Music",
  "version": "0.0.32",
  "identifier": "com.music.vibe",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vibe Music",
        "width": 1280,
        "height": 720,
        "decorations": false,
        "maximized": true,
        "minWidth": 1280,
        "minHeight": 720,
        "visible": false
      },
      {
        "label": "miniplayer",
        "title": "Vibe Music",
        "width": 300,
        "height": 360,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "url": "/?mode=miniplayer"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: blob: data:; font-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost asset:;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$AUDIO/**",
          "$RESOURCE/**"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/justCallMeJeg/vibemusic/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzNjQwRjJFQTcxOUYxNzgKUldSNDhSbW5MZzlrMHhiM1V1dlJDSllDK3NBTmFjdDh4ZzNqSmd3NUR2UU1ZeE9tVVlXREUvQ3AK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "licenseFile": "LICENSE.txt"
  }
}
